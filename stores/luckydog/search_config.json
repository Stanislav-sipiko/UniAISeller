{
  "_comment": "Store-level search & dialog policy. Kernel reads this, never hardcodes it.",

  "use_llm_retrieval": true,

  "catalog_fields": ["category", "animal"],

  "score_threshold": 0.30,
  "on_zero_results": "ABORT",
  "abort_categories": ["meds", "vet", "pharmacy", "медикаменти", "ліки"],

  "attribute_filter": {
    "field": "Тварина",
    "field_aliases": ["animal", "вид тварини", "для тварини", "pet_type"],
    "hard_filter": true,
    "score_match": 1.3,
    "value_translations": {
      "кіт":    ["cat", "кот", "кіт", "котик", "кошка"],
      "кішка":  ["cat", "кот", "кіт", "котик", "кошка"],
      "кот":    ["cat", "кот", "кіт", "котик", "кошка"],
      "кошка":  ["cat", "кот", "кіт", "котик", "кошка"],
      "собака": ["dog", "собака", "пес", "пёс"],
      "пес":    ["dog", "собака", "пес", "пёс"],
      "пёс":    ["dog", "собака", "пес", "пёс"]
    },
    "title_exclusions": {
      "кіт": ["для собак", "собачий"],
      "кішка": ["для собак", "собачий"],
      "собака": ["для котів", "котячий"],
      "пес": ["для котів", "котячий"]
    }
  },

  "label_buyer": "Покупець",
  "label_consultant": "Консультант",

  "example_properties": {},

  "context_ttl_min": 15,
  "min_price_threshold": 10,

  "troll_prompt": "troll_prompt.md",
  "troll_responses": [
    "Цікавий запит! Може, підберемо щось реальне для вашого улюбленця? 🐾",
    "Такого в каталозі немає, але є багато чудових речей! 😄",
    "Ми спеціалізуємось на реальних товарах для реальних тварин 🐶🐱"
  ],

  "not_found_secure_text": "На жаль, ліки та ветпрепарати ми не продаємо. Зверніться до ветеринарної аптеки. 🐾"
}